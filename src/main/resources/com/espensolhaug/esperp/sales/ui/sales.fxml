<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.espensolhaug.esperp.sales.ui.SalesController">
    <padding>
        <Insets topRightBottomLeft="10"/>
    </padding>
    <GridPane hgap="10" vgap="10">
        <padding>
            <Insets topRightBottomLeft="10"/>
        </padding>
    <TextField fx:id="customerField" GridPane.rowIndex="0" promptText="Enter customer name..."/>
    <TextField fx:id="cashierField" GridPane.rowIndex="1" promptText="Enter cashier name..."/>
    <TextField fx:id="storeField" GridPane.rowIndex="2" promptText="Enter store name..."/>
    <ChoiceBox fx:id="paymentBox" GridPane.rowIndex="3" />
    <TextField fx:id="productField" GridPane.rowIndex="4" promptText="Enter product name..."/>
    <TextField fx:id="quantityField" GridPane.rowIndex="5" promptText="Enter quantity"/>
    <TextField fx:id="priceField" GridPane.rowIndex="6" promptText="Enter price"/>
    <Button fx:id="submitButton" text="Submit" GridPane.rowIndex="7" onAction="#handleSubmitButtonAction"/>
    </GridPane>

    <TableView fx:id="salesTable">
        <columns>
            <TableColumn fx:id="idColumn" text="ID"/>
            <TableColumn fx:id="customerColumn" text="Customer"/>
            <TableColumn fx:id="totalColumn" text="Total"/>
            <TableColumn fx:id="statusColumn" text="Status"/>
        </columns>
    </TableView>
</VBox>